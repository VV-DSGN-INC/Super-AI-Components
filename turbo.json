{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "public/r/**"]
    },
    "lint": {},
    "typecheck": {},
    "test": {},
    "check:tokens": {},
    "build:registry": {
      "outputs": ["public/r/**"],
      "env": ["REGISTRY_URL"]
    }
  }
}
